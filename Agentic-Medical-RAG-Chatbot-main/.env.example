# ================================================
# MediScan Environment Variables Template
# ================================================
# Copy this file to .env and fill in your API keys
# At least ONE LLM API Key is required (Groq recommended)

# === LLM API Keys (at least ONE required) ===
GROQ_API_KEY=gsk_your_groq_api_key_here
GEMINI_API_KEY=your_google_gemini_key_here

# === Optional LLM Providers ===
OPENAI_API_KEY=sk-your_openai_key_here
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# === HuggingFace (for embeddings - optional) ===
HUGGINGFACE_API_TOKEN=hf_your_huggingface_token_here

# === Web Search (optional) ===
TAVILY_API_KEY=tvly-your_tavily_key_here

# ================================================
# HOW TO GET API KEYS:
# ================================================
# Groq (FREE, Fast):     https://console.groq.com/keys
# Google Gemini (FREE):  https://aistudio.google.com/apikey
# OpenAI (Paid):         https://platform.openai.com/api-keys
# HuggingFace (FREE):    https://huggingface.co/settings/tokens
# Tavily (FREE tier):    https://tavily.com/
